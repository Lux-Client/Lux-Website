PORT=3001
NODE_ENV=production

ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-long-random-secret

# Preferred PostgreSQL connection string
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Fallback if DATABASE_URL is not set
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL=false

# Source MariaDB (only needed for one-time migration script)
# You can use either MARIADB_URL or MARIADB_* values below
MARIADB_URL=
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=your-mariadb-user
MARIADB_PASSWORD=your-mariadb-password
MARIADB_NAME=your-mariadb-db

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
CALLBACK_URL=https://your-domain.tld/auth/google/callback

# Optional, comma-separated
ALLOWED_ORIGINS=https://your-domain.tld

# Optional runtime storage path
DATA_DIR=/app/data
