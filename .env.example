PORT=3001
NODE_ENV=production

ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-long-random-secret

# Preferred PostgreSQL connection string
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Fallback if DATABASE_URL is not set
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL=false

# Source MariaDB (only needed for one-time migration script)
# You can use either MARIADB_URL or MARIADB_* values below
MARIADB_URL=
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=your-mariadb-user
MARIADB_PASSWORD=your-mariadb-password
MARIADB_NAME=your-mariadb-db

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
CALLBACK_URL=https://your-domain.tld/auth/google/callback

# Optional, comma-separated
ALLOWED_ORIGINS=https://your-domain.tld

# Optional runtime storage path
DATA_DIR=/app/data

# Email notifications (extension approved/rejected, warn/ban), sent via Resend's SMTP relay.
# Off by default — set EMAIL_ENABLED=true once SMTP_PASS/SMTP_FROM are filled in below.
#
# Where to get them: resend.com dashboard -> "API Keys" -> create a key -> that's SMTP_PASS
# (SMTP_USER is always the literal string "resend", already defaulted in code).
# Also verify your sending domain under "Domains" so mail doesn't land in spam (Resend walks
# you through the SPF/DKIM DNS records). SMTP_FROM must be an address on that verified domain.
EMAIL_ENABLED=false
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=noreply@pluginhub.de
SITE_URL=https://lux.pluginhub.de
