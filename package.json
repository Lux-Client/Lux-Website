{
    "name": "mclc-news-admin",
    "version": "1.0.0",
    "description": "Simple News Admin Panel for Lux Client",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node devserver.js",
        "dev:full": "concurrently -k -n \"Backend,Frontend\" -c \"cyan,green\" \"node devserver.js\" \"cd client && npm run dev\"",
        "client:dev": "cd client && npm run dev",
        "client:build": "cd client && npm run build",
        "db:init": "node db_init.js",
        "db:migrate:maria-to-pg": "node migrate-mariadb-to-postgres.js"
    },
    "devDependencies": {
        "concurrently": "^9.0.0"
    },
    "dependencies": {
        "body-parser": "^1.20.2",
        "connect-pg-simple": "^10.0.0",
        "cors": "^2.8.5",
        "dotenv": "^17.3.1",
        "express": "^4.18.2",
        "express-session": "^1.19.0",
        "multer": "^2.0.2",
        "mysql2": "^3.17.1",
        "nodemailer": "^9.0.3",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "pg": "^8.16.3",
        "sharp": "^0.35.3",
        "socket.io": "^4.8.3"
    }
}
